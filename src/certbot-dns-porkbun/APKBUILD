maintainer="John Long <john@johnsdomain.com>"
pkgname=certbot-dns-porkbun
pkgver=0.10.1
pkgrel=1
pkgdesc="Certbot DNS plugin for Porkbun"
url="https://github.com/infinityofspace/certbot_dns_porkbun"
arch="noarch"
license="MIT"
depends="py3-pkb-client py3-tldextract certbot"
makedepends="py3-gpep517 py3-setuptools"
checkdepends=""
subpackages="$pkgname-pyc"
source="$pkgname-$pkgver.tar.gz::https://github.com/infinityofspace/certbot_dns_porkbun/archive/refs/tags/v$pkgver.tar.gz"
builddir="$srcdir/certbot_dns_porkbun-$pkgver"


build() {
	gpep517 build-wheel \
		--wheel-dir .dist \
		--output-fd 3 3>&1 >&2
}

package() {
	python3 -m installer -d "$pkgdir" \
		.dist/*.whl

	rm -r "$pkgdir"/usr/lib/python*/site-packages/tests
}

sha512sums="
